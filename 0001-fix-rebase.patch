-        print("min_val is scalar")
         min_ub_tmp = min_val
 
     # Ensure value is not less than minimum
@@ -799,23 +796,22 @@ def npuir_clamp(src: tir.Buffer, dst: Optional[tir.Buffer], min_val: PrimExpr, m
         tir.op.Op.get("tl.npuir_max"),
