     if isinstance(max_val, tir.Buffer):
         max_ub_tmp = _to_region(max_val, "rw", max_val.shape)
     else:
-        print("max_val is scalar")
         max_ub_tmp = max_val
 
     # Ensure value is not greater than maximum
     min_call = tir.call_intrin(
         "handle",
         tir.op.Op.get("tl.npuir_min"),
-        tmp_mem_tmp,
+        dst_tmp,
